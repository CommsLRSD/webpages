<script>
	(function()
		{
			var customSelect = document.getElementById('dhCustomSelect');
			var optionsElements = document.querySelectorAll('.dh-option');
			var activeIcon = document.getElementById('dhActiveIcon');
			var activeText = document.getElementById('dhActiveText');

			var frame = document.getElementById('dhFrame');
			var counter = document.getElementById('dhCounter');
			var loading = document.getElementById('dhLoading');
			var prevBtn = document.getElementById('dhPrev');
			var nextBtn = document.getElementById('dhNext');
			var fsBtn = document.getElementById('dhFullscreen');
			var viewer = document.getElementById('dhViewer');
			var helpBtn = document.getElementById('dhHelpBtn');
			var directLink = document.getElementById('dhDirectLink');
			var iframeWrap = document.getElementById('dhIframeWrap');
			var mobileListItems = document.getElementById('dhMobileListItems');
			var mobileHelpBtn = document.getElementById('dhMobileHelpBtn');
			var mobileHelpModal = document.getElementById('dhMobileHelpModal');
			var mobileHelpClose = document.getElementById('dhMobileHelpClose');

			var currentIndex = 0;
			var totalDashboards = optionsElements.length;

			// Build the mobile dashboard list from the existing dropdown options
				(function buildMobileList()
			{
				if (!mobileListItems) return;
				optionsElements.forEach(function(opt)
				{
					var url = opt.getAttribute('data-url');
					var title = opt.getAttribute('data-title');
					var icon = opt.getAttribute('data-icon');

					var a = document.createElement('a');
					a.className = 'dh-mobile-list-item';
					a.href = url;
					a.target = '_blank';
					a.rel = 'noopener';

					var img = document.createElement('img');
					img.src = icon;
					img.alt = '';

					var text = document.createElement('span');
					text.className = 'dh-mobile-list-text';
					text.textContent = title;

					var arrow = document.createElement('span');
					arrow.className = 'dh-mobile-list-arrow';
					arrow.textContent = '↗';

					a.appendChild(img);
					a.appendChild(text);
					a.appendChild(arrow);
					mobileListItems.appendChild(a);
				});
			})();

			// Mobile help modal wiring
			if (mobileHelpBtn && mobileHelpModal && mobileHelpClose)
			{
				mobileHelpBtn.addEventListener('click', function()
				{
					mobileHelpModal.classList.add('active');
				});
				mobileHelpClose.addEventListener('click', function()
				{
					mobileHelpModal.classList.remove('active');
				});
				mobileHelpModal.addEventListener('click', function(e)
				{
					if (e.target === mobileHelpModal) mobileHelpModal.classList.remove('active');
				});
			}

			function requestFullscreenSafe(el)
			{
				try
				{
					if (el.requestFullscreen) el.requestFullscreen();
					else if (el.webkitRequestFullscreen) el.webkitRequestFullscreen();
					else if (el.mozRequestFullScreen) el.mozRequestFullScreen();
					else if (el.msRequestFullscreen) el.msRequestFullscreen();
				}
				catch (e)
				{}
			}

			// Close <details> when clicking outside
			document.addEventListener('click', function(e)
			{
				if (!customSelect.contains(e.target))
				{
					customSelect.removeAttribute('open');
				}
			});

			function loadDashboard(idx)
			{
				if (idx < 0 || idx >= totalDashboards) return;

				currentIndex = idx;
				var targetOption = optionsElements[idx];
				var url = targetOption.getAttribute('data-url');
				var title = targetOption.getAttribute('data-title');
				var iconSrc = targetOption.getAttribute('data-icon');

				optionsElements.forEach(function(opt)
				{
					opt.classList.remove('selected');
				});
				targetOption.classList.add('selected');

				activeText.textContent = title;
				activeIcon.src = iconSrc;

				counter.textContent = (idx + 1) + ' / ' + totalDashboards;

				if (frame.src !== url)
				{
					loading.classList.add('active');
					frame.src = url;
				}

				if (directLink) directLink.href = url;

				customSelect.removeAttribute('open');
			}

			frame.onload = function()
			{
				loading.classList.remove('active');
			};

			function nextDashboard()
			{
				var newIdx = (currentIndex + 1) % totalDashboards;
				loadDashboard(newIdx);
			}

			function prevDashboard()
			{
				var newIdx = (currentIndex - 1 + totalDashboards) % totalDashboards;
				loadDashboard(newIdx);
			}

			function toggleFullscreen()
			{
				var fsElement = document.fullscreenElement || document.webkitFullscreenElement || document.mozFullScreenElement || document.msFullscreenElement;
				if (!fsElement)
				{
					requestFullscreenSafe(viewer);
				}
				else
				{
					if (document.exitFullscreen) document.exitFullscreen();
					else if (document.webkitExitFullscreen) document.webkitExitFullscreen();
					else if (document.mozCancelFullScreen) document.mozCancelFullScreen();
					else if (document.msExitFullscreen) document.msExitFullscreen();
				}
			}

			fsBtn.addEventListener('click', toggleFullscreen);

			optionsElements.forEach(function(option)
			{
				option.addEventListener('click', function(e)
				{
					e.stopPropagation();
					var idx = parseInt(this.getAttribute('data-index'), 10);
					loadDashboard(idx);
				});
			});

			prevBtn.addEventListener('click', prevDashboard);
			nextBtn.addEventListener('click', nextDashboard);

			document.addEventListener('keydown', function(e)
			{
				if (e.target.tagName === 'INPUT' || e.target.tagName === 'TEXTAREA') return;
				if (e.key === 'ArrowLeft') prevDashboard();
				if (e.key === 'ArrowRight') nextDashboard();
				if (e.key === 'f' || e.key === 'F') toggleFullscreen();
			});

			// ============================================================
			// SPOTLIGHT TUTORIAL
			// ============================================================
			var tourBackdrop = document.getElementById('dhTourBackdrop');
			var tourSpotlight = document.getElementById('dhTourSpotlight');
			var tourTooltip = document.getElementById('dhTourTooltip');
			var tourStep = document.getElementById('dhTourStep');
			var tourTitle = document.getElementById('dhTourTitle');
			var tourBody = document.getElementById('dhTourBody');
			var tourSkip = document.getElementById('dhTourSkip');
			var tourBack = document.getElementById('dhTourBack');
			var tourNext = document.getElementById('dhTourNext');

			var tourSteps = [
			{
				targetId: 'dhCustomSelect',
				title: 'Choose a Dashboard',
				body: 'Click here to open the menu and pick from any of the 12 available dashboards.'
			},
			{
				targetId: 'dhIframeWrap',
				title: 'Explore the Dashboard',
				body: 'This is your Power BI report. Many reports have multiple pages. Use the page navigation built into the report (typically in a sidebar on the left, but in some instances arrows at the bottom of the report) to switch between pages. You can also click directly on many charts, bars, or data points to filter and explore the underlying data in more specific detail.',
				tooltipPlacement: 'matchPrevTopCenterIframe'
			},
			{
				targetId: 'dhPrev',
				title: 'Switch Between Dashboards',
				body: 'Use the left and right arrows to quickly jump to the previous or next dashboard. You can also use the ← and → keys on your keyboard.',
				targetGroup: ['dhPrev', 'dhNext']
			},
			{
				targetId: 'dhFullscreen',
				title: 'Go Fullscreen',
				body: 'Click here to expand the dashboard to fill your entire screen for a focused view. Press Esc or the F key to exit.'
			},
			{
				targetId: 'dhHelpBtn',
				title: 'Need Help Again?',
				body: 'Click this Help button anytime to revisit this tour.'
			}];

			var tourIndex = 0;
			var tourActive = false;
			var firstStepTooltipTop = null;

			function getCombinedRect(ids)
			{
				var rects = ids.map(function(id)
				{
					return document.getElementById(id).getBoundingClientRect();
				});
				var top = Math.min.apply(null, rects.map(function(r)
				{
					return r.top;
				}));
				var left = Math.min.apply(null, rects.map(function(r)
				{
					return r.left;
				}));
				var right = Math.max.apply(null, rects.map(function(r)
				{
					return r.right;
				}));
				var bottom = Math.max.apply(null, rects.map(function(r)
				{
					return r.bottom;
				}));
				return {
					top: top,
					left: left,
					width: right - left,
					height: bottom - top
				};
			}

			function positionSpotlightAndTooltip()
			{
				if (!tourActive) return;
				var step = tourSteps[tourIndex];
				var ids = step.targetGroup || [step.targetId];
				var rect = getCombinedRect(ids);

				var pad = 8;
				tourSpotlight.style.top = (rect.top - pad) + 'px';
				tourSpotlight.style.left = (rect.left - pad) + 'px';
				tourSpotlight.style.width = (rect.width + pad * 2) + 'px';
				tourSpotlight.style.height = (rect.height + pad * 2) + 'px';

				var tooltipRect = tourTooltip.getBoundingClientRect();
				var tooltipH = tooltipRect.height || 200;
				var tooltipW = tooltipRect.width || 340;
